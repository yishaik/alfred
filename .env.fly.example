# Required control-plane secrets
BRIDGE_BOT_TOKEN=
BRIDGE_CHAT_ID=

# GitHub: prefer a fine-grained token scoped only to selected repositories.
GH_TOKEN=
GITHUB_OWNER=yishaik

# AI providers. CLI subscription authentication can replace API keys for Claude,
# Codex and Gemini; direct API keys remain useful for router/council calls.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
# Optional: Groq is a different provider from Grok/xAI and is used by Alfred for STT fallback.
GROQ_API_KEY=

# Search / model hub
TAVILY_API_KEY=
HF_TOKEN=

# Deployment providers
VERCEL_TOKEN=
VERCEL_ORG_ID=team_ZKpdeShcRUJptlPmkXbqEqfI
NETLIFY_AUTH_TOKEN=
NETLIFY_TEAM_SLUG=yishaik
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=

# Optional isolated Fly worker execution
FLY_API_TOKEN=
ALFRED_FLY_APP=
ALFRED_WORKER_APP=
ALFRED_WORKER_IMAGE=

# Safety defaults
ALFRED_ALLOW_PRODUCTION_DEPLOY=0
ALFRED_ALLOWED_REPOS=yishaik/alfred
ALFRED_COMMAND_TIMEOUT_SECONDS=1800
ALFRED_MAX_OUTPUT_CHARS=50000
